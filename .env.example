# ============================================================================
# newsromania.info — environment template
# Copy to .env (chmod 600) and fill in. The real .env is NEVER committed,
# never printed, and is filled in by the owner only.
#
# PERSPECTIVE RULE (docs/architecture.md §1): .env holds HOST-perspective
# URLs (loopback dev ports 3132/3179 of the compose containers) because the
# systemd worker timers and manual scripts run on the host via
# `npx payload run`. Inside compose, the app service OVERRIDES DATABASE_URL /
# REDIS_URL with service-DNS values (postgres:5432, redis:6379) — see
# compose.yaml. Never hardcode either perspective in code.
# ============================================================================

# --- App -------------------------------------------------------------------
NODE_ENV=production
# Only port published from the compose stack; nginx proxies to it. The
# Next standalone server reads PORT at runtime (npm scripts pin -p 3100).
# Allowed range on this server: 3100-3199 (see README).
PORT=3100
# Public origin of the site (canonical URLs, OG tags, sitemap, social links).
NEXT_PUBLIC_SITE_URL=https://newsromania.info

# --- Payload CMS -----------------------------------------------------------
# Long random string used by Payload to sign auth tokens (also the salt for
# consent-record IP hashing). Generate with: openssl rand -hex 32
PAYLOAD_SECRET=
# Admin account created by scripts/seed/baseline.mjs (idempotent — only on
# first run). Used to log into /admin; never printed anywhere.
PAYLOAD_ADMIN_EMAIL=
PAYLOAD_ADMIN_PASSWORD=

# --- PostgreSQL (own rootless container — NEVER the host :5432) -------------
# Credentials are unique to this project; do not reuse anywhere else.
# POSTGRES_* feed the compose service + scripts/db-backup.sh.
POSTGRES_USER=newsromania
POSTGRES_PASSWORD=
POSTGRES_DB=newsromania
# HOST perspective: loopback dev port 3132 (compose maps 127.0.0.1:3132->5432).
DATABASE_URL=postgres://newsromania:${POSTGRES_PASSWORD}@127.0.0.1:3132/newsromania

# --- Redis (own rootless container; always use the newsromania: key prefix) -
REDIS_PASSWORD=
# HOST perspective: loopback dev port 3179 (compose maps 127.0.0.1:3179->6379).
REDIS_URL=redis://default:${REDIS_PASSWORD}@127.0.0.1:3179
REDIS_KEY_PREFIX=newsromania:

# --- AI summarization / captions (src/lib/llm.ts) ---------------------------
# DECIDED (owner, 2026-07-06): OpenAI is the summarization/chat provider.
OPENAI_API_KEY=
# Chat/summarization model, e.g. gpt-5.4-mini
OPENAI_MODEL_CHAT=
# Provider routing: which LLM provider serves anonymous visitors vs members.
# Only "openai" is implemented; the split exists so providers can diverge
# later without code changes.
AI_DEFAULT_PROVIDER_PUBLIC=openai
AI_DEFAULT_PROVIDER_MEMBER=openai
# Optional alternative provider (cost/quality comparison, PROJECT_BRIEF §14).
# ANTHROPIC_API_KEY=

# --- Stock photos for AI articles (src/lib/stock-photos.ts) -----------------
# Royalty-free lead images for OUR AI-written articles ONLY. Aggregated items
# always hotlink the publisher's own image and never use these. Order is fixed:
# Pexels first, Pixabay as fallback. Both are FREE, owner-provided keys — leave
# BLANK until the owner adds them (the code returns null gracefully with no key
# and the article simply renders with no lead image; never a placeholder).
# NOTE: API-sourced photos REQUIRE visible attribution (rendered as the image
# caption) and MUST NOT be used to show trademarks/logos in a commercial
# context — pick neutral, concept-level search terms, never a brand name.
# Pexels sends the RAW key in the Authorization header (NOT a Bearer token).
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- Google AdSense (site review PENDING — slots render blank until approved)
# Publisher ID is public-facing; safe in code and in this example.
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-8098077913729716
# Ad PREVIEW mode: '1' renders labelled demo boxes in every ad slot so the
# owner can SEE ad placement while AdSense review is pending (never fake ads).
# MUST be '0' for public launch. Build-time flag (compose build.args + Dockerfile).
NEXT_PUBLIC_AD_PREVIEW=0

# --- Amazon Creators API (EU region, LWA auth — vendored SDK) ---------------
# From Associates Central; version 3.2 = EU + LWA per the SDK README.
AMAZON_CREATORS_CREDENTIAL_ID=
AMAZON_CREATORS_CREDENTIAL_SECRET=
AMAZON_CREATORS_CREDENTIAL_VERSION=3.2
# Tracking/partner tag; must match the marketplace of each API request.
# Seeded into site-config as www.amazon.de -> this tag (pending owner
# confirmation of the registered marketplace — docs/ads-operations.md).
AMAZON_PARTNER_TAG_DEFAULT=newsr01-21
# House Amazon ads (owner v2.4): while the live Creators API is gated on
# sales-eligibility (AssociateNotEligible) it returns nothing, so Amazon slots
# fall back to the geo-matched SiteStripe HOUSE bestsellers — REAL affiliate
# products with the marketplace-correct tag, shown in PRODUCTION now. This is a
# DEDICATED switch, NOT tied to NEXT_PUBLIC_AD_PREVIEW. Default ON (an unset var
# reads as enabled); set to '0' to turn the house fallback off once the live API
# is eligible and serving. Server-only (the feed's house product is resolved
# server-side and serialized into the /api/feed batch).
AMAZON_HOUSE_ADS=1

# --- Umami self-hosted analytics (cookieless, GDPR-friendly — §7) ------------
# Umami runs as its OWN compose service (ghcr.io umami:postgresql-latest) on a
# SEPARATE `umami` database + role on the EXISTING postgres container (never
# the app DB/schema — one-time create step in docs/operations.md §11). Served
# SAME-ORIGIN via /stats/* (next.config rewrite → internal umami:3000), so the
# tracker is first-party and needs NO consent (Umami sets no cookies).
# Signs the Umami session/JWT. Generate with: openssl rand -hex 32
UMAMI_APP_SECRET=
# Credentials for the separate `umami` DB/role (host psql + the umami service).
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=
UMAMI_DB_NAME=umami
# Website id (a UUID) for the tracker <script data-website-id>. Read at RUNTIME
# by a server component (src/components/analytics/UmamiScript.tsx), NOT inlined
# at build — so changing it only needs an app RESTART, never a rebuild. BLANK
# until INTEGRATE (or the owner) creates the "newsromania.info" website in the
# Umami admin (first-run, docs/operations.md §11) and copies the real UUID here;
# with no id the tracker renders nothing. The value 'stats' is NOT valid — it
# must be the UUID Umami generates for the website.
UMAMI_WEBSITE_ID=

# --- IP geolocation (geoip-lite — src/lib/geo.ts) ----------------------------
# geoip-lite ships a bundled snapshot; this key is used ONLY by the manual
# database refresh command documented in src/lib/geo.ts:
#   node node_modules/geoip-lite/scripts/updatedb.js license_key=$MAXMIND_LICENSE_KEY
MAXMIND_LICENSE_KEY=

# ============================================================================
# Optional dev/test flags — read from env by scripts, never needed in prod .env
# ============================================================================
# Ingest worker offline fixture (scripts/worker/ingest.mjs):
# INGEST_FIXTURE=scripts/worker/fixtures/sample-feed.xml
# Social worker preview without LLM calls or writes (scripts/worker/social.mjs;
# CLI equivalents: -- --dry-run / -- --limit N, capped at 15):
# SOCIAL_DRY_RUN=1
# SOCIAL_LIMIT=5
# Hourly Facebook "impact of the hour" fan-out (scripts/worker/social.mjs
# --impact; docs/facebook-hourly-runbook.md). OWNER FILLS: the (up to 5)
# Facebook GROUP URLs the account belongs to, newline/comma/space-separated —
# only facebook.com/groups/… URLs are accepted. Until set, only the page row
# is queued (groups pending). The page URL itself lives in /admin site-config.
# SOCIAL_FB_GROUPS="https://facebook.com/groups/aaa https://facebook.com/groups/bbb"
# WordPress import budgets (scripts/seed/import-wordpress.mjs):
# IMPORT_MAX_SUMMARIES=60
# IMPORT_MAX_IMAGES=30
# IMPORT_LIMIT=0
# WordPress import source (one-time seed) — defaults to the owner's live site:
# SEED_SOURCE_URL=https://newsromania.info
# Smoke-test target (scripts/smoke.sh):
# SMOKE_BASE_URL=http://127.0.0.1:3100
